	(text "*** POPULATION WARNING ***\nHFBR-1412TZ and IF-E97 are MUTUALLY EXCLUSIVE.\n- To use ST Fiber: Populate HFBR and 27Ω resistor.\n- To use Bare Fiber: Populate IF-E97 and 47Ω resistor.\nDO NOT populate both transmitters on the same channel."
		(exclude_from_sim no)
		(at 195.072 74.168 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "66519926-db68-4013-8022-54a31074c9ed")
	)
	(text "E-Stop LED Indicator"
		(exclude_from_sim no)
		(at 126.238 145.034 0)
		(effects
			(font
				(size 1.016 1.016)
				(thickness 0.127)
			)
		)
		(uuid "6fe35784-92f9-428c-b5a8-2ca96c582154")
	)
	(text "1. HFBR-1412TZ (ST Fiber)\nVf: ~1.7V @ 60mA\nR = (3.3V - 1.7V) / 0.06A = 26.6 Ω -> 27 Ω\nPower Dissipation: P = R * I^2 = 27 * (0.06)^2 = 0.097 W\n\n2. IF-E97 (Bare Fiber)\nVf: ~1.9V @ 30mA (Conservative safe limit)\nR = (3.3V - 1.9V) / 0.03A = 46.6 Ω -> 47 Ω\nPower Dissipation: P = 47 * (0.03)^2 = 0.042 W"
		(exclude_from_sim no)
		(at 224.536 148.844 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "7e7350a7-8a4b-4d26-83e8-2718b18130eb")
	)
	(text "Fail-Safe E-Stop Circuit.\nSwitch is NC (Normally Closed) to GND.\nIf cable breaks or switch is pushed, \nPull-Up resistor sets Gate to 3.3V -> PMOS OFF.\nE_STOP must be routed to STM32 TIMx_BKIN pin \nfor hardware PWM shutdown."
		(exclude_from_sim no)
		(at 54.102 73.66 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "7eff54ec-6263-44ce-9029-25c8d311002d")
	)
	(text "CH2 Output"
